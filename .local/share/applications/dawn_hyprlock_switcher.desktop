[Desktop Entry]
Type=Application
Name=Dusky Hyprlock Theme Manager
GenericName=Lock Screen Theme Switcher
Comment=Switch Hyprlock configurations interactively
Exec=kitty --class dawn_hyprlock_switcher.sh -e /home/dusk/user_scripts/hyprlock/dawn_hyprlock_switcher.sh
Icon=preferences-desktop-screensaver
Terminal=false
Categories=Settings;DesktopSettings;Utility;
Keywords=dawn;hyprland;hyprlock;theme;config;
StartupNotify=false
