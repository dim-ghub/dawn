[Desktop Entry]
Type=Application
Name=Dusky GSettings TUI
GenericName=Appearance Configurator
Comment=Real-time GTK, theme, and desktop environment configurator
Exec=kitty --class dawn_gsettings.sh -e /home/dusk/user_scripts/gtk/dawn_gsettings.sh
Terminal=false
Categories=Settings;DesktopSettings;System;Utility;
Keywords=dawn;hyprland;gsettings;gtk;theme;appearance;nemo;nautilus;tui;config;settings;
Icon=preferences-desktop-theme
StartupNotify=true
StartupWMClass=dawn_gsettings.sh
