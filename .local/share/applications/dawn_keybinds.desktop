[Desktop Entry]
Type=Application
Name=Dusky Keybind Manager
GenericName=Keybind Editor
Comment=Advanced TUI for managing Dusky keybinds with conflict resolution
Exec=kitty --hold --class dawn_keybinds.sh -e /home/dusk/user_scripts/hypr/dawn_keybinds.sh
Icon=preferences-desktop-keyboard
Terminal=false
Categories=System;Settings;Utility;
Keywords=dawn;keybinds;hyprland;config;tui;bind;shortcut;
StartupNotify=true
