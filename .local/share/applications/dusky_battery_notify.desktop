[Desktop Entry]
Type=Application
Name=Dusky Battery
GenericName=Battery Notify Configuration
Comment=Configure Battery Timeout Settings
Exec=kitty --class dawn_battery_notify.sh -e /home/dusk/user_scripts/battery/notify/dawn_battery_notify.sh
Terminal=false
Categories=Settings;System;
Keywords=dawn;notification;battery;timeout;
Icon=preferences-system-power
StartupNotify=true
