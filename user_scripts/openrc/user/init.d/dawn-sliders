#!/sbin/openrc-run

name="Dusky Sliders"
description="Dusky sliders daemon for system controls"
supervisor=supervise-daemon
command="/usr/bin/python3"
command_args="${HOME}/user_scripts/sliders/dawn_sliders.py"

depend() {
	need dbus
	after pipewire
}

export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"